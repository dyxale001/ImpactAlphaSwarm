# Backend environment variables for Sentiment Scout
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here

LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=AlphaSwarm
LANGSMITH_TRACING=true

SUPABASE_URL=_
SUPABASE_SERVICE_ROLE_KEY=_

API_CORS_ORIGINS=http://localhost:5173

# Google Cloud Natural Language API (dual-signal sentiment alongside VADER).
GOOGLE_NLP_API_KEY=
# Optional tuning (defaults shown): monthly unit cap (free tier guard) and how
# many of the most-engaged posts per ticker also get a GCP signal.
GOOGLE_NLP_MONTHLY_BUDGET=500
GCP_SENTIMENT_TOP_N=5

# Nightly scheduled run (/api/analysis/run-daily). DAILY_RUN_SECRET must match the
# X-Daily-Run-Secret header on the Cloud Scheduler job; if unset the endpoint is
# disabled (503). Generate with: openssl rand -hex 32
DAILY_RUN_SECRET=your_daily_run_secret_here
# Only refresh users whose last run is within this many days (default 7).
DAILY_ACTIVE_DAYS=7